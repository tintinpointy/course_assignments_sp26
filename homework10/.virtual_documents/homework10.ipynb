import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
from astropy import units as u
from astropy import constants as const

df = pd.read_csv("solar_system.csv")
print(df.shape)
df = df.set_index("Attribute").T #Quite literally transposes the data as how it would a matrix (rows = columns, columns = rows)
df.index.name = "Planet" #Add "Planet" to index column name along with "Attribute"
df.reset_index(inplace = True) #Separate the columns: "Planet" is now the column with all the planet names; "Attribute" is now the index
df.columns.name = None #Get rid of the attribute name
print(df.shape)
# Before Transpose: 20 rows and 11 columns; After Transpose: 10 rows and 21 columns
# What's different about the structure is tghat it has an extra column now instead of an extra row
for col in df:
    print(col)
